{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-packages/refs/heads/main/packages/pi-permission-system/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": false,
  "yoloMode": false,

  "permission": {
    "*": "allow",

    "grep": "allow",
    "find": "allow",

    "external_directory": {
      "*": "ask",

      "/tmp/*": "allow",
      "/tmp": "allow",
      "~/.agents/skills/*": "allow",
      "~/.pi/agent/skills/*": "allow",
      "~/.pi/agent/npm/*": "allow",
      "~/.pi/agent/sessions/*": "allow",
      "~/.pi/agent/repos/*": "allow",

      "*/node_modules/@earendil-works/*": "allow",
      "*/node_modules/@earendil-works": "allow",

      "~/.cargo/*": "allow",
      "~/.local/share/rtk/*": "allow",
      "~/appdata/local/rtk/*": "allow"
    },

    "path": {
      "*.env": "deny",
      "*.env.*": "deny",
      "~/.ssh/*": "deny",

      "~/.pi/agent/auth.json": "deny",
      "~/.pi/agent/models.json": "deny"
    },

    "bash": {
      "Remove-Item *": "ask",
      "remove-item *": "ask",
      "rm *": "ask",
      "del *": "ask",
      "erase *": "ask",
      "rd *": "ask",
      "rmdir *": "ask",
      "ri *": "ask",
      "mv *": "ask",

      "cmd /c del *": "ask",
      "cmd /c erase *": "ask",
      "cmd /c rd *": "ask",
      "cmd /c rmdir *": "ask",
      "cmd.exe /c del *": "ask",
      "cmd.exe /c erase *": "ask",
      "cmd.exe /c rd *": "ask",
      "cmd.exe /c rmdir *": "ask",

      "powershell *Remove-Item*": "ask",
      "powershell.exe *Remove-Item*": "ask",
      "pwsh *Remove-Item*": "ask",
      "pwsh.exe *Remove-Item*": "ask",

      "git clean *": "ask",
      "git reset --hard *": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",

      "Clear-Content *": "ask",
      "Set-Content *": "ask",
      "Out-File *": "ask",
      "Move-Item *": "ask",
      "Rename-Item *": "ask"
    }
  }
}

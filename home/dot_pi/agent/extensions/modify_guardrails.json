{{- /* chezmoi:modify-template */ -}}
{{- $old := dict -}}
{{- if ne (.chezmoi.stdin | trim) "" -}}
{{- $old = fromJson .chezmoi.stdin -}}
{{- end -}}

{{- $new := includeTemplate "pi/guardrails.json" | fromJson -}}

{{- if hasKey $old "version" -}}
{{- $new = $new | setValueAtPath "version" (get $old "version") -}}
{{- end -}}

{{- if hasKey $old "onboarding" -}}
{{- $new = $new | setValueAtPath "onboarding" (get $old "onboarding") -}}
{{- end -}}

{{- $new | toPrettyJson }}

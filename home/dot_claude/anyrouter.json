{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_BASE_URL": "https://a-ocnfniawgw.cn-shanghai.fcapp.run",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "ANTHROPIC_BETAS": "context-1m-2025-08-07",
    "autoDreamEnabled": "true",
    "hasCompletedOnboarding": "true",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_REASONING_MODEL": "claude-opus-4-8[1m]"
  },
  "attribution": { "commit": "", "pr": "" },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": ["Bash(*)", "Read(~/.cargo/**)", "Read(~/.local/share/rtk/**)"],
    "deny": ["Bash(rm *)", "Bash(*sudo*)", "Bash(ask *)", "Bash(curl *)", "Bash(wget *)", "Read(./secrets/**)"]
  },
  "hooks": { "PreToolUse": [{ "matcher": "Bash", "hooks": [{ "type": "command", "command": "rtk hook claude" }] }] },
  "language": "Chinese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "max",
  "theme": "auto",
  "tui": "fullscreen",
  "teammateMode": "in-process"
}

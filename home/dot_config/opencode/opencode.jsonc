{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@tarquinen/opencode-dcp@latest", "opencode-wakatime@latest"],
  "share": "disabled",
  "username": "<!--!>",
  "model": "openai/gpt-5.4",
  "small_model": "google/gemini-3-flash-free",
  "autoupdate": false,
  "instructions": ["AGENTS.md", "openspec/AGENTS.md"],
  "compaction": { "auto": true, "prune": true, "reserved": 16000 },
  "lsp": false,
  "permission": {
    "edit": "ask",
    "bash": { "git *": "ask", "rm *": "ask", "*": "allow" },
    "external_directory": {
      "~/.cargo/**": "allow",
      "~/.local/share/rtk": "allow",
      "~/.config/wxbot/**": "allow",
      "~/.local/state/wxbot/**": "allow"
    }
  },
  "default_agent": "build",
  "agent": {
    "plan": {
      "disable": false,
      "permission": {
        "edit": { "*": "deny", "*.md": "allow", "*.mdx": "allow" },
        "write": { "*": "deny", "*.md": "allow", "*.mdx": "allow" },
        "bash": "allow"
      }
    },
    "build": { "disable": false, "permission": { "edit": "allow", "write": "allow", "bash": "allow" } },
    "explore": { "permission": { "edit": "deny", "write": "deny", "bash": "allow" } }
  },
  "formatter": { "rust-formatter": { "command": ["rustfmt", "+nightly", "$FILE"], "extensions": [".rs"] } },
  "watcher": {
    "ignore": [
      "node_modules",
      "bun.lock",
      "tmp",
      "**/.git",
      "**/.cache",
      "**/dist",
      "**/build",
      "**/.next",
      "**/__pycache__",
      "**/.venv",
      "**/target",
      "**/.gradle"
    ]
  },
  "mcp": {
    "context7": { "type": "remote", "url": "https://mcp.context7.com/mcp", "enabled": true },
    "tavily-remote": {
      "type": "remote",
      "url": "https://api.laolilin.com/proxy/tavily/mcp",
      "enabled": false,
      "oauth": false,
      "headers": { "Authorization": "Bearer {env:TAVILY_TOKEN}" }
    },
    "sequential-thinking": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },
  "provider": {
    "openai": {
      "options": { "baseURL": "{env:AI_BASE_URL}/v1", "store": true },
      "models": { "gpt-5.4": { "limit": { "context": 272000, "output": 128000 } } }
    },
    // "anthropic": {
    //   "name": "claude",
    //   "id": "anthropic",
    //   "npm": "@ai-sdk/anthropic",
    //   "options": {
    //     "baseURL": "{env:AI_BASE_URL}/v1",
    //     "setCacheKey": true
    //   },
    //   "models": {}
    // },
    "google": {
      "name": "Google",
      "id": "google",
      "npm": "@ai-sdk/google",
      "options": { "baseURL": "{env:AI_BASE_URL}/v1beta", "apiKey": "{env:AI_BASE_TOKEN}" },
      "models": {
        "gemini-3-flash-free": {
          "id": "gemini-3-flash-free",
          "name": "Gemini 3 Flash Free",
          "release_date": "2025-11-18",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 250000, "output": 64000 },
          "cost": { "input": 0.5, "output": 3, "cache_read": 0.05 },
          "options": { "thinkingConfig": { "includeThoughts": true } },
          "modalities": { "input": ["text", "image", "video", "audio", "pdf"], "output": ["text"] },
          "variants": {
            "minimal": { "thinkingConfig": { "thinkingLevel": "minimal" } },
            "low": { "thinkingConfig": { "thinkingLevel": "low" } },
            "medium": { "thinkingConfig": { "thinkingLevel": "medium" } },
            "high": { "thinkingConfig": { "thinkingLevel": "high" } }
          }
        },
        "gemini-flash-lite": {
          "id": "gemini-flash-lite-latest",
          "name": "Gemini Flash Lite Latest",
          "release_date": "2025-06-17",
          "reasoning": true,
          "limit": { "context": 1048576, "output": 65536 },
          "options": { "includeThoughts": true },
          "cost": { "input": 0.1, "output": 0.4, "cache_read": 0.025 },
          "modalities": { "input": ["text", "image", "audio", "video", "pdf"], "output": ["text"] }
        }
      }
    },
    "nvidia": { "options": { "baseURL": "{env:AI_BASE_URL}/v1", "apiKey": "{env:AI_BASE_TOKEN}" }, "models": {} },
    "openrouter": { "options": { "baseURL": "{env:AI_BASE_URL}/v1" }, "models": {} },
    "private": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Private",
      "options": { "baseURL": "{env:AI_BASE_URL}/v1", "apiKey": "{env:AI_BASE_TOKEN}" },
      "models": {
        "glm-5.1": {
          "attachment": false,
          "cost": { "cache_read": 0.26, "input": 1.4, "output": 4.4 },
          "family": "glm",
          "id": "z-ai/glm-5.1",
          "name": "GLM 5.1",
          "modalities": { "input": ["text"], "output": ["text"] },
          "options": { "thinking": { "type": "enabled" } },
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 202752, "output": 131072 },
          "variants": {
            "none": { "thinking": { "type": "disabled" } },
            "low": { "thinking": { "type": "enabled", "budgetTokens": 8000 } },
            "medium": { "thinking": { "type": "enabled", "budgetTokens": 24000 } },
            "high": { "thinking": { "type": "enabled", "budgetTokens": 48000 } },
            "max": { "thinking": { "type": "enabled", "budgetTokens": 64000 } }
          }
        },
        "qwen3.5": {
          "id": "Qwen/Qwen3.5-397B-A17B",
          "name": "Qwen3.5",
          "reasoning": true,
          "tool_call": true,
          "options": { "thinking": { "type": "enabled" } },
          "limit": { "context": 262144, "output": 32768 },
          "modalities": { "input": ["text", "image", "audio", "video", "pdf"], "output": ["text"] }
        },
        "DeepSeek Pro": {
          "id": "deepseek-v4-pro",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 384000 },
          "options": { "thinking": { "type": "enabled" }, "reasoning_effort": "high" },
          "variants": {
            "none": { "thinking": { "type": "disabled" } },
            "high": { "reasoning_effort": "high" },
            "max": { "reasoning_effort": "max" }
          }
        },
        "DeepSeek Flash": {
          "id": "deepseek-v4-flash",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 384000 },
          "options": { "thinking": { "type": "enabled" }, "reasoning_effort": "high" },
          "variants": {
            "none": { "thinking": { "type": "disabled" } },
            "high": { "reasoning_effort": "high" },
            "max": { "reasoning_effort": "max" }
          }
        },
        "Minimax M2.7": {
          "id": "minimaxai/minimax-m2.7",
          "reasoning": true,
          "tool_call": true,
          "options": { "thinking": { "type": "enabled" } },
          "limit": { "context": 190000, "output": 64000 }
        }
      }
    }
  }
}
